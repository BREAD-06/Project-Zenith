# ============================================================
# Project Zenith — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
#
#   cp .env.local.example .env.local
#
# .env.local is git-ignored and will NOT be committed.
# ============================================================

# Cesium Ion Access Token (required)
# Sign up for free at https://ion.cesium.com/signup
# Then go to Access Tokens → copy your Default Token
NEXT_PUBLIC_CESIUM_ION_TOKEN=your_cesium_token_here
